---
import type { Quiz } from "../types/Quiz";
type Props = {
  quiz: Quiz[];
  title?: boolean;
};
const { quiz, title } = Astro.props;
---

<div class="exam">
  {title && <div class="exam__badge">Examen interactivo</div>}

  {
    quiz.map((question) => (
      <section class="exam__question">
        <h2 class="exam__question-title">{question.question}</h2>

        {question.code && (
          <pre class="exam__code">
            <code class="exam__code-inner language-js">{question.code}</code>
          </pre>
        )}

        <div class="exam__options">
          {question.options.map((option, index) => (
            <div class="exam__option">
              <input
                class="exam__option-input"
                type="radio"
                id={`q${question.id}-option${index}`}
                name={`q${question.id}`}
              />
              <label
                class={`exam__option-card ${
                  option.isCorrect
                    ? "exam__option-card--correct"
                    : "exam__option-card--incorrect"
                }`}
                for={`q${question.id}-option${index}`}
              >
                <div class="exam__option-header">
                  <span class="exam__option-radio" />
                  <span class="exam__option-title">{option.text}</span>
                </div>
                {/* TEXTO DE EXPLICACIÓN (separar a ExamenIntroExplanation) */}
                <p class="exam__option-explication">{option.explication}</p>
              </label>
            </div>
          ))}
        </div>
      </section>
    ))
  }
</div>

<style scoped>
  .exam {
    background: var(--bg-card);
    border-radius: 1.25rem;
    padding: 1.5rem;
    border: 1px solid var(--border-card);
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .exam__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--sl-color-yellow);
    background: var(--sl-color-gray-6);
    border-radius: 999px;
    padding: 0.35rem 0.9rem;
    border: 1px solid var(--border-card);
    align-self: flex-start;
  }

  .exam__question {
    background: var(--bg-card);
    border-radius: 0.75rem;
    padding: 1.25rem 1.5rem;
    border: 1px solid var(--border-card);
  }

  .exam__question-title {
    color: var(--sl-color-yellow);
    font-size: 1.1rem;
    font-weight: 700;
    margin: 0 0 1.25rem;
  }

  .exam__options {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .exam__option {
    position: relative;
  }

  .exam__option-input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .exam__option-card {
    display: block;
    background: var(--sl-color-black);
    border-radius: 0.75rem;
    border: 1px solid var(--border-card);
    padding: 0.9rem 1.1rem;
    cursor: pointer;
    font-size: 0.95rem;
    color: #e5e7eb;
    transition:
      border-color 0.15s ease,
      background 0.15s ease,
      box-shadow 0.15s ease,
      transform 0.05s ease;
  }

  .exam__option-header {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.5rem;
    font-weight: 600;
  }

  .exam__option-radio {
    width: 16px;
    height: 16px;
    border-radius: 999px;
    border: 2px solid var(--sl-color-yellow);
    box-shadow: 0 0 0 2px rgba(250, 204, 21, 0.2);
    position: relative;
    flex-shrink: 0;
  }

  .exam__option-title {
    color: var(--sl-color-yellow);
  }

  .exam__option-card:hover {
    border-color: var(--sl-color-yellow);
  }

  .exam__option-explication {
    display: none;
    margin: 0.35rem 0 0;
    line-height: 1.5;
  }

  .exam__option-input:checked + .exam__option-card {
    border-color: var(--sl-color-yellow);
    transform: translateY(-1px);
  }

  .exam__option-input:checked + .exam__option-card.exam__option-card--correct {
    background: #062f2b;
    border-color: #16a34a;
    box-shadow: 0 0 0 1px rgba(34, 197, 94, 0.5);
  }

  .exam__option-input:checked
    + .exam__option-card.exam__option-card--incorrect {
    background: #3a0d12;
    border-color: #7a1e28;
    box-shadow: 0 0 0 1px rgba(248, 113, 113, 0.295);
  }

  .exam__option-input:checked + .exam__option-card .exam__option-radio::after {
    content: "";
    position: absolute;
    inset: 2px;
    border-radius: 999px;
    background: var(--sl-color-yellow);
  }

  .exam__option-input:checked + .exam__option-card .exam__option-explication {
    display: block;
  }
  .exam__code {
    background: #070a0f;
    border-radius: 0.75rem;
    padding: 1rem 1.25rem;
    margin-bottom: 1.25rem;
    border: 1px solid #111827;
    overflow-x: auto;
  }

  .exam__code-inner {
    font-family: var(--__sl-font-mono);
    font-size: 0.9rem;
    color: #facc15;
    white-space: pre;
  }

  @media (max-width: 640px) {
    .exam {
      padding: 1.25rem;
      border-radius: 1rem;
    }

    .exam__question {
      padding: 1rem 1.1rem;
    }
  }
</style>

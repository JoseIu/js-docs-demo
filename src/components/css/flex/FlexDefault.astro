<div class="flex-default">
  <div class="first-container">
    <div class="first-container__item">1</div>
    <div class="first-container__item">1</div>
  </div>
</div>

<button class="change-flex">Agregar flex</button>

<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }
  .flex-default {
    margin-top: 2rem;
    padding: 1rem;
    background-color: #eee;
  }

  .first-container {
    width: 100%;
    height: 400px;

    border: 1px solid red;
    color: #222;
  }

  .first-container__item {
    width: 200px;
    padding: 1rem;
    list-style: 200px;
    text-align: center;
    border: 1px solid blue;
    background-color: #ccc;
  }
  .change-flex {
    margin-top: 1rem;
    padding: 0.5rem 1rem;
    background-color: #333;
    color: #fff;
    border: none;
    cursor: pointer;
    border-radius: 0.4rem;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const button = document.querySelector('.change-flex') as HTMLButtonElement;
    const firstContainer = document.querySelector('.first-container') as HTMLElement;
    console.log(button);

    button.addEventListener('click', () => {
      firstContainer.style.display = 'flex';

      if (button.innerText === 'Agregar flex') {
        button.innerText = 'Eliminar flex';
        return;
      }
      button.innerText = 'Agregar flex';
      firstContainer.style.removeProperty('display');
    });
  });
</script>

{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
   "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@components/*": [
        "./src/components/*"
      ],
      "@content/*": [
        "./src/content/*"
      ],
      "@docs/*": [
        "./src/content/docs/*"
      ],
      "@db/*": [
        "./src/db/*"
      ],
    },

  },
}
